<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ShadowMe - A True Travelmate</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/themes/dark.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body>

  <header>
    <div class="header-title">
      <h1>ShadowMe - A True Travelmate</h1>
      <p>Simplify travel planning and select the optimal seat for protection from sunlight</p>
    </div>
    <a href="https://satyakampandya.com" target="_blank" rel="noopener noreferrer" class="dev-profile-btn">
      <span>Satyakam Pandya</span>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
  </header>

  <div class="container">
    <!-- Card 1: Form Inputs -->
    <div class="card form-card">
      <form id="recommendation-form" onsubmit="event.preventDefault(); submitForm();">
        <div class="form-group">
          <label for="source-input">Source Location</label>
          <input type="text" id="source-input" placeholder="Search origin location..." required autocomplete="off">
          <input type="hidden" id="source-coords">
          <span id="source-coords-lbl" class="coords-indicator">Coordinates: 0.000, 0.000</span>
        </div>

        <div class="form-group">
          <button type="button" class="btn-swap" onclick="swapLocations();" title="Swap Source and Destination">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 11 21 7 17 3"></polyline><line x1="21" y1="7" x2="9" y2="7"></line><polyline points="7 13 3 17 7 21"></polyline><line x1="3" y1="17" x2="15" y2="17"></line></svg>
          </button>
          <label for="dest-input">Destination Location</label>
          <input type="text" id="dest-input" placeholder="Search destination location..." required autocomplete="off">
          <input type="hidden" id="dest-coords">
          <span id="dest-coords-lbl" class="coords-indicator">Coordinates: 0.000, 0.000</span>
        </div>

        <div class="form-group">
          <label for="departure-input">Departure Date & Time</label>
          <input type="text" id="departure-input" placeholder="Select Departure Date & Time..." required>
        </div>

        <div class="form-group" id="route-options-group" style="display: none;">
          <label>Select Route Option</label>
          <div id="route-options-list" class="route-options-list"></div>
        </div>

        <button type="submit" id="submit-btn" class="btn-submit" disabled>
          <span id="btn-text">ShadowMe</span>
          <div id="btn-spinner" class="spinner"></div>
        </button>
      </form>
    </div>

    <!-- Card 2: Results Display -->
    <div class="card result-panel" id="result-panel">
      <!-- Placeholder State -->
      <div id="placeholder-state" class="placeholder-state">
        <div class="placeholder-icon">☀️</div>
        <h3>Recommendation Insights</h3>
        <p style="color: var(--text-muted); margin-top: 0.5rem; font-size: 0.85rem; padding: 0 1rem;">
          Submit your journey to view the recommended side of the vehicle and direct sunlight exposure times.
        </p>
      </div>

      <!-- Loading State (Skeleton) -->
      <div id="loading-state" style="display: none; width: 100%;">
        <div class="skeleton skeleton-badge"></div>
        <div class="skeleton skeleton-text"></div>
        <div class="skeleton skeleton-text-short"></div>
        <div class="skeleton skeleton-bar"></div>
        <div class="skeleton-grid">
          <div class="skeleton skeleton-grid-item"></div>
          <div class="skeleton skeleton-grid-item"></div>
        </div>
      </div>

      <!-- Result Content -->
      <div id="result-content" class="result-content">
        <div id="badge-container">
          <span class="recommendation-badge left" id="recommended-side-badge">Left Side</span>
        </div>
        
        <p class="result-message" id="result-message">
          You should sit on the left side of the vehicle to minimize direct sunlight exposure.
        </p>

        <div class="exposure-breakdown">
          <div class="exposure-labels">
            <span class="lbl-left" id="exposure-lbl-left">Left: 0m</span>
            <span class="lbl-front-behind" id="exposure-lbl-front-behind">Front/Behind: 0m</span>
            <span class="lbl-right" id="exposure-lbl-right">Right: 0m</span>
            <span class="lbl-neutral" id="exposure-lbl-neutral" style="color: #10b981; font-weight: 600;">Night: 0m</span>
          </div>
          <div class="exposure-bar-container">
            <div class="bar-left" id="bar-left" style="width: 0%"></div>
            <div class="bar-front-behind" id="bar-front-behind" style="width: 0%"></div>
            <div class="bar-right" id="bar-right" style="width: 0%"></div>
            <div class="bar-neutral" id="bar-neutral" style="width: 0%"></div>
          </div>
        </div>

        <div class="details-grid">
          <div class="detail-card">
            <label>Confidence</label>
            <div class="detail-val" id="confidence-val">High</div>
          </div>
          <div class="detail-card">
            <label>Cache Status</label>
            <div class="detail-val" id="cache-val">Miss</div>
          </div>
        </div>

        <!-- Interactive Checkpoint Timeline -->
        <div class="timeline-container" id="timeline-container">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
            <h4 style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); display: flex; align-items: center; gap: 0.4rem;">
              <i data-lucide="route" style="width: 16px; height: 16px; color: var(--accent-primary);"></i> Route Timeline
            </h4>
            <div style="display: flex; align-items: center; gap: 0.75rem;">
              <div class="sim-speed-control" style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.75rem; color: var(--text-muted);">
                <span>Speed:</span>
                <select id="sim-speed-select" onchange="updateSimulationSpeed();" style="background-color: var(--input-bg); border: 1px solid var(--card-border); border-radius: 6px; color: var(--text-color); font-size: 0.75rem; padding: 0.2rem 0.4rem; cursor: pointer; outline: none; transition: border-color 0.2s ease;">
                  <option value="0.5">0.5x</option>
                  <option value="1" selected>1x</option>
                  <option value="2">2x</option>
                  <option value="5">5x</option>
                  <option value="10">10x</option>
                </select>
              </div>
              <button type="button" id="play-sim-btn" class="btn-play-sim" onclick="toggleSimulation();" title="Play Simulation" style="padding: 0.35rem; border-radius: 50%; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; min-width: 28px;">
                <i data-lucide="play" style="width: 14px; height: 14px;"></i>
              </button>
            </div>
          </div>
          <div id="timeline-list" class="timeline-list"></div>
        </div>
      </div>
    </div>

    <!-- Card 3: Interactive Map -->
    <div class="card map-card" style="position: relative;">
      <div id="map"></div>
      
      <!-- Floating Map Legend -->
      <div class="map-legend">
        <div class="legend-title">Checkpoints</div>
        <div class="legend-item">
          <span class="legend-color left"></span>
          <span>Sun on Left Side</span>
        </div>
        <div class="legend-item">
          <span class="legend-color right"></span>
          <span>Sun on Right Side</span>
        </div>
        <div class="legend-item">
          <span class="legend-color neutral"></span>
          <span>Sun Front / Behind</span>
        </div>
        <div class="legend-item">
          <span class="legend-color night"></span>
          <span>Night Time</span>
        </div>
      </div>
    </div>
  </div>

  <footer class="footer">
    <p>Copyright &copy; <%= Time.now.year %> <a href="https://satyakampandya.com" target="_blank" rel="noopener noreferrer" class="footer-link">Satyakam Pandya</a>. All rights reserved.</p>
    <div class="footer-love">
      Made with <span class="heart-icon"> ❤️</span> in India
    </div>
  </footer>

  <script src="/js/admin.js" defer></script>
  <!-- Callback triggers initMap when script finishes loading -->
  <script src="https://maps.googleapis.com/maps/api/js?key=<%= api_key %>&libraries=places,marker&callback=initMap&loading=async" async defer></script>
</body>
</html>
